# Datos del registro de aplicación en Azure AD (los entrega el área de TI)
GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Solo para sincronización del lado del servidor (NUNCA exponer en el navegador)
GRAPH_CLIENT_SECRET=reemplazar-con-el-secreto

# Ubicación del archivo Excel en OneDrive / SharePoint institucional
GRAPH_DRIVE_ID=
GRAPH_ITEM_ID=
GRAPH_WORKSHEET=BASE DE DATOS
